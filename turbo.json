{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": [
    ".prettierrc",
    ".prettierignore",
    "pnpm-workspace.yaml",
    ".nvmrc",
    "packages/tsconfig/*.json"
  ],
  "globalEnv": ["CI", "NODE_ENV"],
  "globalPassThroughEnv": ["TAURI_ENV_PLATFORM", "TAURI_ENV_DEBUG", "TAURI_ENV_TARGET_TRIPLE"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**",
        "index.html",
        "tsconfig.json",
        "vite.config.ts",
        "package.json"
      ],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**",
        "tsconfig.json",
        "package.json"
      ],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**",
        "eslint.config.ts",
        "tsconfig.json",
        "package.json"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**",
        "vitest.config.ts",
        "tsconfig.json",
        "package.json"
      ],
      "outputs": []
    }
  }
}
